{
  "name": "clip-sandbox",
  "version": "1.0.0",
  "description": "",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "build": "node --input-type=module -e \"import { rmSync } from 'node:fs'; rmSync('build', { recursive: true, force: true });\" && tsc -p tsconfig.build.json",
    "start": "npm run build && electron .",
    "test": "npm run e2e",
    "e2e": "npm run build && playwright test",
    "e2e:headed": "playwright test --headed",
    "unit": "vitest --run",
    "typecheck": "tsc -p tsconfig.json",
    "test:all": "npm run unit && npm run e2e",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^24.8.1",
    "@playwright/test": "^1.57.0",
    "electron": "^37.2.0",
    "husky": "^9.1.7",
    "jsdom": "22.1.0",
    "typescript": "^6.0.2",
    "vitest": "0.34.6"
  }
}
